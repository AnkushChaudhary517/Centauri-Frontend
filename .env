# .env is better suited for public variables, ie, variables that should not commited
# For secret variables is better to use DevServerControl tool with set_env_variable: ["KEY", "SECRET"]

# https://www.builder.io/c/docs/using-your-api-key
VITE_PUBLIC_BUILDER_KEY=__BUILDER_PUBLIC_KEY__
PING_MESSAGE="ping pong"

# Frontend URL - Used for OAuth callbacks
# Set this to your frontend domain in production
# In development, it defaults to http://localhost:8080
# FRONTEND_URL=https://yourdomain.com

VITE_API_BASE_URL_LOCALHOST=https://localhost:7206/api/v1
VITE_API_BASE_URL_PRODUCTION=https://api.getcentauri.com/api/v1

# SEO Analysis URLs
VITE_SEO_ANALYZE_URL_LOCALHOST=https://localhost:7206/api/Seo/analyze
VITE_SEO_ANALYZE_URL_PRODUCTION=https://api.getcentauri.com/api/Seo/analyze

# Recommendations URLs
VITE_RECOMMENDATIONS_URL_LOCALHOST=https://localhost:7206/api/Seo/recommendations
VITE_RECOMMENDATIONS_URL_PRODUCTION=https://api.getcentauri.com/api/Seo/recommendations
